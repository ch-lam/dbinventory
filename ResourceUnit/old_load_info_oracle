# =============================================================================
# MSSQL – Inventaire
# =============================================================================

log "Chargement mssql_hosts..."
while read hostname mssql_edition mssql_product_version collation is_clustered \
           activenodename clusternode1 clusternode2 parallel_threshold max_dop \
           min_memory max_memory xp_cmdshell_enabled num_cpus memory_gb \
           os_type install_date service_account env license_type; do
    printf "INSERT INTO mssql_hosts (hostname,mssql_edition,mssql_product_version,collation,is_clustered,activenodename,clusternode1,clusternode2,parallel_threshold,max_dop,min_memory,max_memory,xp_cmdshell_enabled,num_cpus,memory_gb,os_type,install_date,service_account,env,license_type) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$hostname" "$mssql_edition" "$mssql_product_version" "$collation" "$is_clustered" \
           "$activenodename" "$clusternode1" "$clusternode2" "$parallel_threshold" "$max_dop" \
           "$min_memory" "$max_memory" "$xp_cmdshell_enabled" "$num_cpus" "$memory_gb" \
           "$os_type" "$install_date" "$service_account" "$env" "$license_type"
done < lists/hosts_sqlserver.lst | sql_pipe

log "Chargement mssql_database..."
while read hostname database_id database_name database_state recovery_model \
           compatibility_level collation last_backup_date last_backup_diff_date \
           last_backup_log_date create_date is_mirroring_enabled owner agtype agname env; do
    printf "INSERT INTO mssql_database (hostname,database_id,database_name,database_state,recovery_model,compatibility_level,collation,last_backup_date,last_backup_diff_date,last_backup_log_date,create_date,is_mirroring_enabled,owner,agtype,agname,env) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$hostname" "$database_id" "$database_name" "$database_state" "$recovery_model" \
           "$compatibility_level" "$collation" "$last_backup_date" "$last_backup_diff_date" \
           "$last_backup_log_date" "$create_date" "$is_mirroring_enabled" \
           "$owner" "$agtype" "$agname" "$env"
done < lists/db_sqlserver.lst | sql_pipe

log "Chargement mssql_files..."
while read hostname database_name file_id type_desc name physical_name \
           size_mb growth_percent growth_mb max_size env; do
    printf "INSERT INTO mssql_files (hostname,database_name,file_id,type_desc,name,physical_name,size_mb,growth_percent,growth_mb,max_size,env) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$hostname" "$database_name" "$file_id" "$type_desc" "$name" "$physical_name" \
           "$size_mb" "$growth_percent" "$growth_mb" "$max_size" "$env"
done < lists/fileinfo.lst | sql_pipe

log "Chargement mssql_logins..."
while read instance_name LoginName AccountCreationDate LastTimeAccountModified \
           PasswordLastSetTime DefaultDatabase DefaultLanguage IsDisabledChecked \
           IsPolicyChecked IsExpirationChecked IsExpired DaysUntilExpiration \
           IsLocked IsMustChange LockoutTime BadPasswordCount BadPasswordTime \
           HistoryLength LoginSid LoginType HasServerRole; do
    printf "INSERT INTO mssql_logins (instance_name,LoginName,AccountCreationDate,LastTimeAccountModified,PasswordLastSetTime,DefaultDatabase,DefaultLanguage,IsDisabledChecked,IsPolicyChecked,IsExpirationChecked,IsExpired,DaysUntilExpiration,IsLocked,IsMustChange,LockoutTime,BadPasswordCount,BadPasswordTime,HistoryLength,LoginSid,LoginType,HasServerRole) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$instance_name" "$LoginName" "$AccountCreationDate" "$LastTimeAccountModified" \
           "$PasswordLastSetTime" "$DefaultDatabase" "$DefaultLanguage" "$IsDisabledChecked" \
           "$IsPolicyChecked" "$IsExpirationChecked" "$IsExpired" "$DaysUntilExpiration" \
           "$IsLocked" "$IsMustChange" "$LockoutTime" "$BadPasswordCount" "$BadPasswordTime" \
           "$HistoryLength" "$LoginSid" "$LoginType" "$HasServerRole"

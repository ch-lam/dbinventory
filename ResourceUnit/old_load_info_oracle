           "$servername" "$sid" "$login" "$is_disabled" "$modify_date" "$scandate"
done < lists/validatelogin.lst | sql_pipe

log "Chargement mssql_backup..."
while read hostname database_name backup_start_date backup_finish_date backup_type backup_size; do
    printf "INSERT INTO mssql_backup (hostname,database_name,backup_start_date,backup_finish_date,backup_type,backup_size) VALUES ('%s','%s','%s','%s','%s','%s');\n" \

#!/bin/bash
# =============================================================================
# load_info_oracle  –  Charge les fichiers .lst dans la base Oracle inventory
# =============================================================================
set -euo pipefail

# ── Connexion Oracle ──────────────────────────────────────────────────────────
ORACLE_USER="inventory"
ORACLE_PASS="change_me"
ORACLE_DSN="dbhost:1521/INVENTORYDB"    # Easy Connect : host:port/service_name

# ── Séparateur CSV ────────────────────────────────────────────────────────────
IFS=,

# ── Helpers ───────────────────────────────────────────────────────────────────
log() { echo "[$(date '+%H:%M:%S')] $*"; }

# Encapsule un flux de SQL dans une session sqlplus (options + NLS + COMMIT + EXIT)
sql_pipe() {
    {
        printf 'WHENEVER SQLERROR EXIT FAILURE ROLLBACK\n'
        printf 'SET DEFINE OFF\nSET FEEDBACK OFF\nSET ECHO OFF\n'
        printf "ALTER SESSION SET NLS_DATE_FORMAT='YYYY-MM-DD HH24:MI:SS';\n"
        printf "ALTER SESSION SET NLS_TIMESTAMP_FORMAT='YYYY-MM-DD HH24:MI:SS.FF';\n"
        cat
        printf 'COMMIT;\nEXIT;\n'
    } | sqlplus -S "${ORACLE_USER}/${ORACLE_PASS}@${ORACLE_DSN}"
}


# =============================================================================
# TRUNCATE des tables de staging  (DDL – auto-commit Oracle)
# =============================================================================
log "Truncate des tables de staging..."
sql_pipe <<'SQL'
TRUNCATE TABLE oracle_hosts;
TRUNCATE TABLE oracle_users;
TRUNCATE TABLE oracle_services;
TRUNCATE TABLE oracle_pdbs;
TRUNCATE TABLE oracle_database_list;
TRUNCATE TABLE oracle_dataguard;
TRUNCATE TABLE oracle_psu;
TRUNCATE TABLE oracle_lms;
TRUNCATE TABLE oracle_client_info;
TRUNCATE TABLE oracle_backup_info;
TRUNCATE TABLE oracle_security_admin_high_privs;
TRUNCATE TABLE oracle_security_audit_enable;
TRUNCATE TABLE oracle_security_default_profile;
TRUNCATE TABLE oracle_security_default_user_pwd;
TRUNCATE TABLE oracle_security_high_role_privs;
TRUNCATE TABLE oracle_security_high_sys_privs;
TRUNCATE TABLE oracle_security_high_tab_privs;
TRUNCATE TABLE oracle_security_network_encryption;
TRUNCATE TABLE oracle_security_parameter;
TRUNCATE TABLE oracle_security_profile;
TRUNCATE TABLE oracle_security_tablespace_encrypted;
TRUNCATE TABLE oracle_database_capacity_planning_cpu_mem;
TRUNCATE TABLE oracle_database_capacity_planning_dbsize;
TRUNCATE TABLE oracle_database_capacity_planning_dbsize_segs;
TRUNCATE TABLE mssql_hosts;
TRUNCATE TABLE mssql_database;
TRUNCATE TABLE mssql_backup;
TRUNCATE TABLE mssql_files;
TRUNCATE TABLE mssql_logins;
TRUNCATE TABLE mssql_loginwoperm;
TRUNCATE TABLE mssql_users;
TRUNCATE TABLE mssql_validatelogin;
TRUNCATE TABLE chl_ipam_comment;
SQL


# =============================================================================
# ORACLE – Inventaire
# =============================================================================

log "Chargement oracle_hosts..."
while read environment license_type hostname num_cpus memory_gb os_type; do
    printf "INSERT INTO oracle_hosts (environment,license_type,hostname,num_cpus,memory_gb,os_type) VALUES ('%s','%s','%s','%s','%s','%s');\n" \
           "$environment" "$license_type" "$hostname" "$num_cpus" "$memory_gb" "$os_type"
done < lists/hosts.lst | sql_pipe

log "Chargement oracle_users..."
while read hostname db_name instance_name pdb_name username account_status; do
    printf "INSERT INTO oracle_users (hostname,db_name,instance_name,pdb_name,username,account_status) VALUES ('%s','%s','%s','%s','%s','%s');\n" \
           "$hostname" "$db_name" "$instance_name" "$pdb_name" "$username" "$account_status"
done < lists/databases_users.lst | sql_pipe

log "Chargement oracle_services..."
while read hostname instance_name pdb_name service_name; do
    printf "INSERT INTO oracle_services (hostname,instance_name,pdb_name,service_name) VALUES ('%s','%s','%s','%s');\n" \
           "$hostname" "$instance_name" "$pdb_name" "$service_name"
done < lists/databases_service.lst | sql_pipe

log "Chargement oracle_pdbs..."
while read hostname instance_name pdb_name pdb_state; do
    printf "INSERT INTO oracle_pdbs (hostname,instance_name,pdb_name,pdb_state) VALUES ('%s','%s','%s','%s');\n" \
           "$hostname" "$instance_name" "$pdb_name" "$pdb_state"
done < lists/databases_pdb_list.lst | sql_pipe

log "Chargement oracle_database_list..."
while read environment license_type hostname instance_name db_version db_name \
           db_log_mode db_role db_unique_name db_charset db_edition rac_state \
           sga pga asm_free asm_total easy_connect_tns database_type; do
    printf "INSERT INTO oracle_database_list (environment,license_type,hostname,instance_name,db_version,db_name,db_log_mode,db_role,db_unique_name,db_charset,db_edition,rac_state,sga,pga,asm_free,asm_total,easy_connect_tns,database_type) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$environment" "$license_type" "$hostname" "$instance_name" "$db_version" "$db_name" \
           "$db_log_mode" "$db_role" "$db_unique_name" "$db_charset" "$db_edition" "$rac_state" \
           "$sga" "$pga" "$asm_free" "$asm_total" "$easy_connect_tns" "$database_type"
done < lists/databases.lst | sql_pipe

log "Chargement oracle_dataguard..."
while read primary_db standby_db protection_mode pdb_list_impacted service_list_impacted; do
    printf "INSERT INTO oracle_dataguard (primary_db,standby_db,protection_mode,pdb_list_impacted,service_list_impacted) VALUES ('%s','%s','%s','%s','%s');\n" \
           "$primary_db" "$standby_db" "$protection_mode" "$pdb_list_impacted" "$service_list_impacted"
done < lists/databases_dataguard.lst | sql_pipe

log "Chargement oracle_psu..."
while read db_name db_version psu_applied; do
    printf "INSERT INTO oracle_psu (db_name,db_version,psu_applied) VALUES ('%s','%s','%s');\n" \
           "$db_name" "$db_version" "$psu_applied"
done < lists/databases_psu_list.lst | sql_pipe

log "Chargement oracle_lms..."
# Colonnes group_id, con_id, last_sample_date : présentes dans le fichier, non insérées
while read group_id con_id db_pdb_name product_name usage_detected \
           last_sample_date first_usage_date last_usage_date db_name hostname; do
    printf "INSERT INTO oracle_lms (hostname,db_name,db_pdb_name,product_name,usage_detected,first_usage_date,last_usage_date) VALUES ('%s','%s','%s','%s','%s','%s','%s');\n" \
           "$hostname" "$db_name" "$db_pdb_name" "$product_name" "$usage_detected" \
           "$first_usage_date" "$last_usage_date"
done < lists/databases_lms.lst | sql_pipe

log "Chargement oracle_client_info..."
while read db_name db_version environment pdb_name client_version client_driver \
           username client_host service_name failover_type failover_method; do
    printf "INSERT INTO oracle_client_info (db_name,db_version,environment,pdb_name,client_version,client_driver,username,client_host,service_name,failover_type,failover_method) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$db_name" "$db_version" "$environment" "$pdb_name" "$client_version" "$client_driver" \
           "$username" "$client_host" "$service_name" "$failover_type" "$failover_method"
done < lists/databases_oracle_client_version.lst | sql_pipe


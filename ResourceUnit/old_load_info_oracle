           defaultdbname defaultschemaname principalid sid; do
    printf "INSERT INTO mssql_users (instance_name,database_name,name,groupname,loginname,defaultdbname,defaultschemaname,principalid,sid) VALUES ('%s','%s','%s','%s','%s','%s','%s','%s','%s');\n" \
           "$instance_name" "$database_name" "$name" "$groupname" "$loginname" \
           "$defaultdbname" "$defaultschemaname" "$principalid" "$sid"

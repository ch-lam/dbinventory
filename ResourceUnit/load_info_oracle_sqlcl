#!/bin/bash
# =============================================================================
# load_info_oracle_sqlcl  –  Charge les fichiers .lst dans Oracle via SQLcl
#
# Prérequis : SQLcl 22.x+  (commande : sql)
# Avantages vs sqlplus : chargement bulk (SQL*Loader), session unique,
#                        mapping de colonnes inline, échappement natif des données
# =============================================================================
set -euo pipefail

# ── Connexion Oracle ──────────────────────────────────────────────────────────
ORACLE_USER="inventory"
ORACLE_PASS="change_me"
ORACLE_DSN="dbhost:1521/INVENTORYDB"    # Easy Connect : host:port/service_name

# ── Helpers ───────────────────────────────────────────────────────────────────
log() { echo "[$(date '+%H:%M:%S')] $*"; }

log "Démarrage du chargement via SQLcl..."

# =============================================================================
# Session SQLcl unique : TRUNCATE + LOAD
# =============================================================================
sql -S "${ORACLE_USER}/${ORACLE_PASS}@${ORACLE_DSN}" <<'SQLCL_SESSION'
WHENEVER SQLERROR EXIT FAILURE ROLLBACK
SET FEEDBACK OFF
SET ECHO     OFF
SET LOADFORMAT CSV
SET LOAD DELIMITER ','
SET LOAD SKIP 0

ALTER SESSION SET NLS_DATE_FORMAT      = 'YYYY-MM-DD HH24:MI:SS';
ALTER SESSION SET NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';


-- ===========================================================================
-- TRUNCATE des tables de staging  (DDL – auto-commit Oracle)
-- ===========================================================================
TRUNCATE TABLE oracle_hosts;
TRUNCATE TABLE oracle_users;
TRUNCATE TABLE oracle_services;
TRUNCATE TABLE oracle_pdbs;
TRUNCATE TABLE oracle_database_list;
TRUNCATE TABLE oracle_dataguard;
TRUNCATE TABLE oracle_psu;
TRUNCATE TABLE oracle_lms;
TRUNCATE TABLE oracle_client_info;
TRUNCATE TABLE oracle_backup_info;
TRUNCATE TABLE oracle_security_admin_high_privs;
TRUNCATE TABLE oracle_security_audit_enable;
TRUNCATE TABLE oracle_security_default_profile;
TRUNCATE TABLE oracle_security_default_user_pwd;
TRUNCATE TABLE oracle_security_high_role_privs;
TRUNCATE TABLE oracle_security_high_sys_privs;
TRUNCATE TABLE oracle_security_high_tab_privs;
TRUNCATE TABLE oracle_security_network_encryption;
TRUNCATE TABLE oracle_security_parameter;
TRUNCATE TABLE oracle_security_profile;
TRUNCATE TABLE oracle_security_tablespace_encrypted;
TRUNCATE TABLE oracle_database_capacity_planning_cpu_mem;
TRUNCATE TABLE oracle_database_capacity_planning_dbsize;
TRUNCATE TABLE oracle_database_capacity_planning_dbsize_segs;
TRUNCATE TABLE mssql_hosts;
TRUNCATE TABLE mssql_database;
TRUNCATE TABLE mssql_backup;
TRUNCATE TABLE mssql_files;
TRUNCATE TABLE mssql_logins;
TRUNCATE TABLE mssql_loginwoperm;
TRUNCATE TABLE mssql_users;
TRUNCATE TABLE mssql_validatelogin;
TRUNCATE TABLE chl_ipam_comment;


-- ===========================================================================
-- ORACLE – Inventaire
-- ===========================================================================

LOAD oracle_hosts (environment,license_type,hostname,num_cpus,memory_gb,os_type) lists/hosts.lst

LOAD oracle_users (hostname,db_name,instance_name,pdb_name,username,account_status) lists/databases_users.lst

LOAD oracle_services (hostname,instance_name,pdb_name,service_name) lists/databases_service.lst

LOAD oracle_pdbs (hostname,instance_name,pdb_name,pdb_state) lists/databases_pdb_list.lst

LOAD oracle_database_list (environment,license_type,hostname,instance_name,db_version,db_name,db_log_mode,db_role,db_unique_name,db_charset,db_edition,rac_state,sga,pga,asm_free,asm_total,easy_connect_tns,database_type) lists/databases.lst

LOAD oracle_dataguard (primary_db,standby_db,protection_mode,pdb_list_impacted,service_list_impacted) lists/databases_dataguard.lst

LOAD oracle_psu (db_name,db_version,psu_applied) lists/databases_psu_list.lst

-- oracle_lms : colonnes group_id(1), con_id(2), last_sample_date(6) ignorées via FILLER
LOAD oracle_lms (filler1 FILLER,filler2 FILLER,db_pdb_name,product_name,usage_detected,filler6 FILLER,first_usage_date,last_usage_date,db_name,hostname) lists/databases_lms.lst

LOAD oracle_client_info (db_name,db_version,environment,pdb_name,client_version,client_driver,username,client_host,service_name,failover_type,failover_method) lists/databases_oracle_client_version.lst

-- oracle_backup_info : désactivé (données non disponibles)
-- LOAD oracle_backup_info (db_name,backup_type,status,start_time,end_time,elapsed_time) lists/databases_backup.lst


-- ===========================================================================
-- ORACLE – Sécurité
-- ===========================================================================

LOAD oracle_security_admin_high_privs (db_name,username) lists/databases_security_admin_high_privs.lst

LOAD oracle_security_default_user_pwd (db_name,pdb_name,username) lists/databases_security_default_user_pwd.lst

LOAD oracle_security_high_role_privs (db_name,pdb_name,username,privilege) lists/databases_security_high_role_privs.lst

LOAD oracle_security_high_sys_privs (db_name,pdb_name,username,privilege) lists/databases_security_high_sys_privs.lst

LOAD oracle_security_high_tab_privs (db_name,pdb_name,username,privilege) lists/databases_security_high_tab_privs.lst

LOAD oracle_security_profile (db_name,pdb_name,profile,resource_name,limit_value) lists/databases_security_profile.lst

LOAD oracle_security_default_profile (db_name,pdb_name,username,profile,oracle_managed) lists/databases_security_default_profile.lst

LOAD oracle_security_parameter (db_name,parameter_value,parameter_name) lists/databases_security_parameter.lst

LOAD oracle_security_audit_enable (db_name,pdb_name,audit_parameter,audit_activated) lists/databases_security_audit_enable.lst

LOAD oracle_security_tablespace_encrypted (db_name,pdb_name,tablespace_name,encrypted) lists/databases_security_tablespace.lst

LOAD oracle_security_network_encryption (db_name,sqlnet_encryption) lists/databases_security_network_encryption.lst


-- ===========================================================================
-- ORACLE – Capacity Planning
-- ===========================================================================

LOAD oracle_database_capacity_planning_dbsize (db_name,pdb_name,tablespace_name,size_mb) lists/databases_size_usage.lst

LOAD oracle_database_capacity_planning_dbsize_segs (db_name,pdb_name,tablespace_name,sum_segment_mb) lists/databases_size_usage_seg.lst

LOAD oracle_database_capacity_planning_cpu_mem (pdb_name,cpu_time_minutes,avg_sga_mb,avg_pga_mb,avg_buffer_cache_mb,avg_shared_pool_mb) lists/databases_metrics_cpu_mem_usage.lst

-- Note : variable cpu_time_minutes dans le fichier -> colonne dbcpu_time_minutes en base
LOAD oracle_database_capacity_planning_cpu_service_history (pdb_name,service_name,dbcpu_time_minutes) lists/databases_metrics_cpu_by_service_usage.lst


-- ===========================================================================
-- MSSQL – Inventaire
-- ===========================================================================

LOAD mssql_hosts (hostname,mssql_edition,mssql_product_version,collation,is_clustered,activenodename,clusternode1,clusternode2,parallel_threshold,max_dop,min_memory,max_memory,xp_cmdshell_enabled,num_cpus,memory_gb,os_type,install_date,service_account,env,license_type) lists/hosts_sqlserver.lst

LOAD mssql_database (hostname,database_id,database_name,database_state,recovery_model,compatibility_level,collation,last_backup_date,last_backup_diff_date,last_backup_log_date,create_date,is_mirroring_enabled,owner,agtype,agname,env) lists/db_sqlserver.lst

LOAD mssql_files (hostname,database_name,file_id,type_desc,name,physical_name,size_mb,growth_percent,growth_mb,max_size,env) lists/fileinfo.lst

LOAD mssql_logins (instance_name,loginname,accountcreationdate,lasttimeaccountmodified,passwordlastsettime,defaultdatabase,defaultlanguage,isdisabledchecked,ispolicychecked,isexpirationchecked,isexpired,daysuntilexpiration,islocked,ismustchange,lockouttime,badpasswordcount,badpasswordtime,historylength,loginsid,logintype,hasserverrole) lists/logininfo.lst

LOAD mssql_users (instance_name,database_name,name,groupname,loginname,defaultdbname,defaultschemaname,principalid,sid) lists/userinfo.lst

LOAD mssql_loginwoperm (instance_name,loginname,type_desc,is_disabled,db_perms,srv_perms,modify_date,scandate) lists/loginwoperm.lst

LOAD mssql_validatelogin (servername,sid,login,is_disabled,modify_date,scandate) lists/validatelogin.lst

LOAD mssql_backup (hostname,database_name,backup_start_date,backup_finish_date,backup_type,backup_size) lists/bu_sqlserver.lst


-- ===========================================================================
-- Divers
-- ===========================================================================

-- Note : colonne renommée 'comments' en Oracle (mot réservé)
LOAD chl_ipam_comment (hostname,comments) lists/chl_ipam_comment.lst

COMMIT;
EXIT;
SQLCL_SESSION


# =============================================================================
# Archivage des fichiers .lst  (reste en bash – hors session SQLcl)
# =============================================================================
DIR_TIME=$(date '+%y%m%d%H%M%S')
mkdir -p "lists/${DIR_TIME}"
cp lists/*.lst "lists/${DIR_TIME}/"

log "Fichiers archivés dans lists/${DIR_TIME}/"
log "Chargement terminé."

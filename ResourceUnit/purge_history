#!/bin/bash
# =============================================================================
# purge_history  –  Purge des tables d'accumulation Oracle inventory
#
# Chaque table d'historique conserve les données sur une fenêtre glissante.
# Exécuter périodiquement (ex. : cron mensuel).
#
# Usage : ./purge_history [nb_mois_retention]
#         Par défaut : 13 mois (1 an + marge d'un cycle)
# =============================================================================
set -euo pipefail

# ── Connexion Oracle ──────────────────────────────────────────────────────────
ORACLE_USER="inventory"
ORACLE_PASS="change_me"
ORACLE_DSN="dbhost:1521/INVENTORYDB"

# ── Rétention ─────────────────────────────────────────────────────────────────
RETENTION_MONTHS="${1:-13}"

# ── Helpers ───────────────────────────────────────────────────────────────────
log() { echo "[$(date '+%H:%M:%S')] $*"; }

sql_pipe() {
    {
        printf 'WHENEVER SQLERROR EXIT FAILURE ROLLBACK\n'
        printf 'SET DEFINE OFF\nSET FEEDBACK ON\nSET ECHO OFF\n'
        cat
        printf 'COMMIT;\nEXIT;\n'
    } | sqlplus -S "${ORACLE_USER}/${ORACLE_PASS}@${ORACLE_DSN}"
}

log "Purge des historiques (rétention : ${RETENTION_MONTHS} mois)..."

sql_pipe <<SQL
-- Seuil de purge
-- Toutes les lignes dont la date de collecte est antérieure à ce seuil sont supprimées.
DEFINE retention = ${RETENTION_MONTHS}

-- ── Oracle – Audit logon ────────────────────────────────────────────────────
DELETE FROM oracle_audit_logon_history
 WHERE date_value < ADD_MONTHS(SYSDATE, -&retention);

-- ── Oracle – Backup ─────────────────────────────────────────────────────────
DELETE FROM oracle_backup_info_history
 WHERE scoring_result < ADD_MONTHS(SYSDATE, -&retention);

DELETE FROM oracle_backup_info_archivelog_gap
 WHERE start_time < ADD_MONTHS(SYSDATE, -&retention);

-- ── Oracle – Security ────────────────────────────────────────────────────────
DELETE FROM oracle_security_history
 WHERE date_value < ADD_MONTHS(SYSDATE, -&retention);

-- ── Oracle – Capacity Planning ───────────────────────────────────────────────
DELETE FROM oracle_database_capacity_planning_cpu_mem_history
 WHERE date_value < ADD_MONTHS(SYSDATE, -&retention);

DELETE FROM oracle_database_capacity_planning_dbsize_history
 WHERE date_value < ADD_MONTHS(SYSDATE, -&retention);

DELETE FROM oracle_database_capacity_planning_cpu_service_history
 WHERE date_value < ADD_MONTHS(SYSDATE, -&retention);

-- ── MSSQL – Backup ───────────────────────────────────────────────────────────
DELETE FROM mssql_backup_info_history
 WHERE scoring_result < ADD_MONTHS(SYSDATE, -&retention);

-- ── MSSQL – Security ─────────────────────────────────────────────────────────
DELETE FROM mssql_security_history
 WHERE date_value < ADD_MONTHS(SYSDATE, -&retention);
SQL

log "Purge terminée."

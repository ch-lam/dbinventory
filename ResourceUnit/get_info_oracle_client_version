export ORACLE_HOME=/inventory/OracleClient/instantclient_23_9
export TNS_ADMIN=/inventory/OracleClient/instantclient_23_9/network
export LD_LIBRARY_PATH=$ORACLE_HOME
export PATH=$PATH:$ORACLE_HOME
export USERNAME_DB="monitoring"
export PASSWORD_DB="F5t9TAcbjLTzhBNE69YeYBTx1BLgOZ"


echo "" > lists/databases_oracle_client_version_temp.lst
rm -rf lists/error_oracle_client_version_db.lst

for db in `cat oracle_database_lists.lst | grep -v "#" | cut -d ";" -f3 | sort -u`
        do
		DB_NAME=`echo ${db} | cut -d ";" -f1`
		DB_VERSION=`echo ${db} | cut -d ";" -f2`
		TNS=`echo ${db} | cut -d ";" -f3`
                ENV=`echo ${db} | cut -d ";" -f4`

###CHECK CONNECT DB
loginchk=`sqlplus dummy/user@${TNS} < /dev/null`
loginchk2=` echo  $loginchk | grep -c ORA-01017`
if [ ${loginchk2} -eq 1 ] ; then
        export CONNECT_CHECK="OK"
else
         echo "${db}" >> lists/error_oracle_client_version_db.lst
fi

###LOOP ONLY IF SCRIPT CAN CONNECT TO DATABASES
if [ `echo ${CONNECT_CHECK} | grep "OK" | wc -l` -eq 1 ]; then
export CONNECT_CHECK="NA"

######Database Client Version Connected
echo "set pages0;
      set linesize 900;
      set feedback off;
      select '${DB_NAME},${DB_VERSION},${ENV},'||PDBS.PDB_NAME||','||INF.CLIENT_VERSION||','||INF.CLIENT_DRIVER||','||SESS.USERNAME||','||SESS.MACHINE||','||SESS.SERVICE_NAME||','||SESS.FAILOVER_TYPE||','||SESS.FAILOVER_METHOD FROM V\$SESSION_CONNECT_INFO INF, V\$SESSION SESS, DBA_PDBS PDBS WHERE CONCAT(INF.SID,INF.SERIAL#)=CONCAT(SESS.SID,SESS.SERIAL#) AND INF.CON_ID=PDBS.PDB_ID AND INF.CLIENT_VERSION <> 'Unknown';" | sqlplus -s ${USERNAME_DB}/${PASSWORD_DB}@${TNS} >> lists/databases_oracle_client_version_temp.lst

####END OF LOOP
fi
done

##Cleanup TEMP FILE
cat lists/databases_oracle_client_version_temp.lst | grep -v "SP2-0157" | grep "," | sort -u | sed '/^$/d' > lists/databases_oracle_client_version.lst

rm -rf lists/databases_oracle_client_version_temp.lst

###CHECK ERROR
if [ -f lists/error_oracle_client_version_db.lst ]; then
       echo "Error to generate CMDB for Oracle Client Version:
             `cat lists/error_oracle_client_version_db.lst`" | mailx -s "Error to generate CMDB for Oracle Client Version" IT-DBA@chl.lu
        exit 1
fi

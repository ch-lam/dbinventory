#GET Hosts List
for hst in `cat mssql_database_lists.lst | grep -v "#" | sort -u`
        do
	export hst=`echo ${hst} | cut -d ":" -f1`
# GET Configuration Options
	sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getconfigoptions.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"
	cat ${hst}_temp.csv | grep -v "affected" | grep -Ev "^$" >> lists/mssql_security_configoptions_temp.lst
        rm -rf ${hst}_temp.csv
# GET Registry Informations        
        sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getregistryinfo.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"
        cat ${hst}_temp.csv | grep -v "affected" | grep -v "The system cannot find the file specified" | grep -v "introuvable" | grep -Ev "^$" >> lists/mssql_security_registryinfo_temp.lst
        rm -rf ${hst}_temp.csv
# GET guest connect permission
        sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getguestconnect.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"

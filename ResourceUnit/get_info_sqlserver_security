export PATH=/opt/mssql-tools18/bin:${PATH}
export USERNAME_DB="monitoring"
export PASSWORD_DB="HY9Xine38wnkC2gLadd2YafJiz5gRw"

echo "" > lists/mssql_security_configoptions_temp.lst

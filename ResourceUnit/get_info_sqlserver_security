        sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getlogins.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"
        cat ${hst}_temp.csv | grep -v "affected" | grep -Ev "^$" >> lists/mssql_security_logins_temp.lst
        rm -rf ${hst}_temp.csv
# GET auditlevel informations
        sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getauditlevel.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"
        cat ${hst}_temp.csv | grep -v "affected" | grep -Ev "^$" >> lists/mssql_security_auditlevel_temp.lst
        rm -rf ${hst}_temp.csv		
# GET SQL Server Audit informations
        sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getsqlserveraudit.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"
        cat ${hst}_temp.csv | grep -v "affected" | grep -Ev "^$" >> lists/mssql_security_sqlserveraudit_temp.lst

        sqlcmd -U ${USERNAME_DB} -S ${hst} -P ${PASSWORD_DB} -C -i /inventory/ResourceUnit/sql/mssql_getencryption.sql -h-1 -W -w 999 -s"," -o "${hst}_temp.csv"
        cat ${hst}_temp.csv | grep -v "affected" | grep -Ev "^$" >> lists/mssql_security_encryption_temp.lst

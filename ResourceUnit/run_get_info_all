#!/bin/bash
# =============================================================================
# run_get_info_all — orchestration collecte inventaire Oracle + MSSQL
# =============================================================================
set -euo pipefail
cd /inventory/ResourceUnit

# Purge des .lst précédents
rm -f /inventory/ResourceUnit/lists/*.lst

# ── Collecte Oracle ───────────────────────────────────────────────────────────
./get_info_oracle               # infra, capacité, segments, dataguard
./get_info_oracle_security      # audit sécurité
./get_info_oracle_lms           # Feature Usage Statistics (LMS)
./get_info_oracle_client_version

# ── Collecte MSSQL ───────────────────────────────────────────────────────────
./get_info_sqlserver

# ── Chargement en base ────────────────────────────────────────────────────────
./load_info                     # MariaDB (production actuelle)
# ./load_info_oracle_sqlcl      # Oracle (nouvelle cible – à activer)

# ── Scoring ──────────────────────────────────────────────────────────────────
mariadb -u root -p"changeme" inventory < sql/oracle_scoring_data.sql

./get_info_sqlserver_security
./load_mssql_security
mariadb -u root -p"changeme" inventory < sql/mssql_scoring_data.sql
